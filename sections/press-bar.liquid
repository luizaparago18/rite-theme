<div class="press-bar">
  <div class="press-bar__track">
    {% assign phrases = section.settings.phrases | default: 'seu ritual diário · beleza que cuida · autocuidado sem excesso · proteção de verdade' | split: '·' %}
    {% for i in (1..3) %}
      {% for phrase in phrases %}<span>{{ phrase | strip }}</span>{% endfor %}
    {% endfor %}
  </div>
</div>

{% schema %}
{
  "name": "Faixa de dizeres",
  "settings": [
    { "type": "text", "id": "phrases", "label": "Frases (separadas por ·)", "default": "seu ritual diário · beleza que cuida · autocuidado sem excesso · proteção de verdade" }
  ],
  "presets": [ { "name": "Faixa de dizeres" } ]
}
{% endschema %}
