<section class="section">
  <div class="container">
    <div class="manifesto">
      <h2 class="manifesto__heading font-heading">{{ section.settings.heading | default: 'Beleza como ritual é Rite' }}</h2>
      <p class="manifesto__body">{{ section.settings.body | default: 'Unimos tratamento e proteção em produtos multifuncionais e práticos. Fáceis de usar quanto de levar com você.' }}</p>
      <a href="{{ section.settings.button_url | default: '/pages/quem-somos' }}" class="btn btn--accent">{{ section.settings.button_label | default: 'Conheça a Rite' }}</a>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Manifesto (teaser)",
  "settings": [
    { "type": "text", "id": "heading", "label": "Título", "default": "Beleza como ritual é Rite" },
    { "type": "textarea", "id": "body", "label": "Texto", "default": "Unimos tratamento e proteção em produtos multifuncionais e práticos. Fáceis de usar quanto de levar com você." },
    { "type": "text", "id": "button_label", "label": "Texto do botão", "default": "Conheça a Rite" },
    { "type": "url", "id": "button_url", "label": "Link do botão" }
  ],
  "presets": [ { "name": "Manifesto (teaser)" } ]
}
{% endschema %}
