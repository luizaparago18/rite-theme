<section class="section" style="padding-top:0;">
  <div class="newsletter">
    <h2 class="newsletter__heading font-heading">{{ section.settings.heading | default: 'Fique por dentro' }}</h2>
    <p class="newsletter__subheading">{{ section.settings.subheading | default: 'Novidades, lançamentos e desconto de boas-vindas direto no seu e-mail.' }}</p>

    {% form 'customer', class: 'newsletter__form' %}
      <input type="hidden" name="contact[tags]" value="newsletter">
      <input type="email" name="contact[email]" placeholder="Digite seu e-mail" required aria-label="E-mail">
      <button type="submit" aria-label="Inscrever">→</button>
    {% endform %}
  </div>
</section>

{% schema %}
{
  "name": "Newsletter",
  "settings": [
    { "type": "text", "id": "heading", "label": "Título", "default": "Fique por dentro" },
    { "type": "textarea", "id": "subheading", "label": "Subtítulo", "default": "Novidades, lançamentos e desconto de boas-vindas direto no seu e-mail." }
  ],
  "presets": [
    { "name": "Newsletter" }
  ]
}
{% endschema %}
