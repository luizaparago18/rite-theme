<header class="site-header">
  <div class="site-header__inner">
    <button class="site-header__mobile-toggle" aria-label="Abrir menu" data-mobile-nav-toggle>
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none"><path d="M3 6h18M3 12h18M3 18h18" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
    </button>

    <a href="{{ routes.root_url }}" class="site-header__logo font-heading">{{ section.settings.logo_text | default: 'rite' }}</a>

    <nav aria-label="Navegação principal">
      <ul class="site-header__nav">
        <li><a href="{{ routes.root_url }}">início</a></li>
        <li><a href="/collections/pele">pele</a></li>
        <li><a href="/collections/cabelo">cabelo</a></li>
        <li><a href="/pages/gummies">suplementos</a></li>
        <li><a href="/pages/rite-clube">rite clube</a></li>
        <li><a href="/pages/quem-somos">quem somos</a></li>
        <li><a href="{{ blog.url | default: '/blogs/news' }}">blog</a></li>
      </ul>
    </nav>

    <div class="site-header__icons">
      <button aria-label="Buscar"><svg width="18" height="18" viewBox="0 0 24 24" fill="none"><circle cx="11" cy="11" r="7" stroke="currentColor" stroke-width="2"/><path d="M21 21l-4-4" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg></button>
      <a href="{{ routes.account_url }}" aria-label="Conta"><svg width="18" height="18" viewBox="0 0 24 24" fill="none"><circle cx="12" cy="8" r="4" stroke="currentColor" stroke-width="2"/><path d="M4 20c0-4 4-6 8-6s8 2 8 6" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg></a>
      <a href="{{ routes.cart_url }}" aria-label="Carrinho">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none"><path d="M4 6h2l1.6 10.6a2 2 0 0 0 2 1.4h7.8a2 2 0 0 0 2-1.6L21 8H7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
        {% if cart.item_count > 0 %}<span class="cart-count">{{ cart.item_count }}</span>{% endif %}
      </a>
    </div>
  </div>
</header>

{% schema %}
{ "name": "Cabeçalho", "settings": [ { "type": "text", "id": "logo_text", "label": "Texto do logo", "default": "rite" } ] }
{% endschema %}
