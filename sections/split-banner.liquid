<section class="section">
  <div class="container">
    <div class="split-banner{% if section.settings.reverse %} split-banner--reverse{% endif %}">
      <div class="split-banner__text">
        {% if section.settings.eyebrow != blank %}
          <p class="hero__eyebrow">{{ section.settings.eyebrow }}</p>
        {% endif %}
        <h2 class="font-heading" style="font-size: clamp(24px,3vw,34px);">{{ section.settings.heading }}</h2>
        {% if section.settings.body != blank %}
          <p>{{ section.settings.body }}</p>
        {% endif %}
        {% if section.settings.button_label != blank %}
          <div><a href="{{ section.settings.button_url | default: '#' }}" class="btn btn--accent">{{ section.settings.button_label }}</a></div>
        {% endif %}
      </div>
      <div class="split-banner__media">
        {% if section.settings.image %}
          <img src="{{ section.settings.image | image_url: width: 800 }}" alt="{{ section.settings.image.alt | escape }}" loading="lazy" width="800" height="{{ section.settings.image.height }}">
        {% else %}
          <div class="product-card__placeholder">Imagem em produção</div>
        {% endif %}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Banner dividido",
  "settings": [
    { "type": "checkbox", "id": "reverse", "label": "Inverter lados (imagem à esquerda)", "default": false },
    { "type": "text", "id": "eyebrow", "label": "Texto pequeno (eyebrow)" },
    { "type": "text", "id": "heading", "label": "Título", "default": "Encontre o seu tom" },
    { "type": "textarea", "id": "body", "label": "Texto", "default": "Responda o quiz e descubra qual protetor combina melhor com você." },
    { "type": "text", "id": "button_label", "label": "Texto do botão", "default": "Responder quiz" },
    { "type": "url", "id": "button_url", "label": "Link do botão" },
    { "type": "image_picker", "id": "image", "label": "Imagem" }
  ],
  "presets": [
    { "name": "Banner dividido" }
  ]
}
{% endschema %}
