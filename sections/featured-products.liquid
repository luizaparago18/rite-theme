<section class="section">
  <div class="container">
    <h2 class="section__heading">{{ section.settings.heading | default: 'mais vendidos' }}</h2>

    <div class="product-grid">
      {% for block in section.blocks %}
        {% if block.settings.product != blank %}
          {% render 'product-card', product: block.settings.product, badge: block.settings.badge, badge_accent: block.settings.badge_accent %}
        {% else %}
          {% render 'product-card', badge: block.settings.badge, badge_accent: block.settings.badge_accent %}
        {% endif %}
      {% endfor %}
    </div>

    <div style="text-align:center; margin-top: var(--space-4);">
      <a href="{{ routes.all_products_collection_url }}" class="btn btn--outline">Ver todos os produtos</a>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Destaques",
  "settings": [
    { "type": "text", "id": "heading", "label": "Título da seção", "default": "Destaques" }
  ],
  "blocks": [
    {
      "type": "product",
      "name": "Produto",
      "settings": [
        { "type": "product", "id": "product", "label": "Produto" },
        { "type": "text", "id": "badge", "label": "Selo (opcional)", "default": "" },
        { "type": "checkbox", "id": "badge_accent", "label": "Selo em amarelo (em vez de preto)", "default": false }
      ]
    }
  ],
  "presets": [
    {
      "name": "Destaques",
      "blocks": [
        { "type": "product", "settings": { "badge": "Mais vendido" } },
        { "type": "product", "settings": { "badge": "10% OFF", "badge_accent": true } },
        { "type": "product" },
        { "type": "product", "settings": { "badge": "20% OFF", "badge_accent": true } }
      ]
    }
  ]
}
{% endschema %}
