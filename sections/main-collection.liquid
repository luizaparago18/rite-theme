<section class="collection-banner">
  <div class="container">
    <h1 class="collection-banner__title font-heading">{{ collection.title | default: 'Coleção' }}</h1>
    {% if collection.description != blank %}
      <div class="collection-banner__desc">{{ collection.description }}</div>
    {% endif %}
  </div>
</section>

<section class="collection-grid-wrap">
  <div class="container">
    {% paginate collection.products by 12 %}
      {% if collection.products.size > 0 %}
        <div class="product-grid">
          {% for product in collection.products %}
            {% render 'product-card', product: product %}
          {% endfor %}
        </div>

        {% if paginate.pages > 1 %}
          <div class="pagination">
            {% if paginate.previous %}<a href="{{ paginate.previous.url }}">← Anterior</a>{% endif %}
            {% for part in paginate.parts %}
              {% if part.is_link %}<a href="{{ part.url }}">{{ part.title }}</a>{% else %}<span class="current">{{ part.title }}</span>{% endif %}
            {% endfor %}
            {% if paginate.next %}<a href="{{ paginate.next.url }}">Próxima →</a>{% endif %}
          </div>
        {% endif %}
      {% else %}
        <p class="collection-empty">Nenhum produto disponível nessa coleção ainda.</p>
      {% endif %}
    {% endpaginate %}
  </div>
</section>

{% schema %}
{
  "name": "Coleção",
  "settings": []
}
{% endschema %}
