<section style="padding: var(--space-6) 0 var(--space-4); text-align:center; background: var(--color-cream);">
  <div class="container">
    <p class="hero__eyebrow" style="color:var(--color-black);">{{ collection.title }}</p>
    <h1 class="font-heading" style="font-size:clamp(28px,4vw,42px); margin-bottom:8px;">
      {{ section.settings.phrase | default: collection.title }}
    </h1>
    {% if collection.description != blank %}
      <div style="max-width:520px; margin:0 auto; color:var(--color-gray); font-size:14px;">{{ collection.description }}</div>
    {% endif %}
  </div>
</section>

<div class="container" style="padding: var(--space-3) 0;">
  <div style="display:flex; justify-content:center; gap:10px; flex-wrap:wrap;">
    <a href="/collections/pele" class="btn {% if collection.handle == 'pele' %}btn--primary{% else %}btn--outline{% endif %}" style="text-transform:lowercase;">pele</a>
    <a href="/collections/cabelo" class="btn {% if collection.handle == 'cabelo' %}btn--primary{% else %}btn--outline{% endif %}" style="text-transform:lowercase;">cabelo</a>
    <a href="/pages/gummies" class="btn btn--outline" style="text-transform:lowercase;">suplementos</a>
    <a href="{{ routes.all_products_collection_url }}" class="btn {% if collection.handle == 'all' %}btn--primary{% else %}btn--outline{% endif %}" style="text-transform:lowercase;">todos</a>
  </div>
</div>

<section class="collection-grid-wrap">
  <div class="container">
    {% paginate collection.products by 12 %}
      {% if collection.products.size > 0 %}
        <div class="product-grid">
          {% for product in collection.products %}
            {% render 'product-card', product: product %}
          {% endfor %}
        </div>
        {% if paginate.pages > 1 %}
          <div class="pagination">
            {% if paginate.previous %}<a href="{{ paginate.previous.url }}">← anterior</a>{% endif %}
            {% for part in paginate.parts %}
              {% if part.is_link %}<a href="{{ part.url }}">{{ part.title }}</a>{% else %}<span class="current">{{ part.title }}</span>{% endif %}
            {% endfor %}
            {% if paginate.next %}<a href="{{ paginate.next.url }}">próxima →</a>{% endif %}
          </div>
        {% endif %}
      {% else %}
        <p class="collection-empty">Nenhum produto disponível nessa coleção ainda.</p>
      {% endif %}
    {% endpaginate %}
  </div>
</section>

{% schema %}
{
  "name": "Coleção",
  "settings": [
    { "type": "text", "id": "phrase", "label": "Frase do banner (opcional — se vazio, usa o nome da coleção)" }
  ]
}
{% endschema %}
