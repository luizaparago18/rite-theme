<section class="section">
  <div class="container">
    <h2 class="section__heading">{{ section.settings.heading | default: 'Compre por categoria' }}</h2>

    <div class="category-grid">
      {% for block in section.blocks %}
        <a href="{{ block.settings.link | default: '#' }}" class="category-card" style="{% if block.settings.image %}background-image:url({{ block.settings.image | image_url: width: 500 }}); background-size:cover; background-position:center;{% endif %}">
          <span class="category-card__label">{{ block.settings.label | default: 'Categoria' }}</span>
        </a>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Categorias",
  "settings": [
    { "type": "text", "id": "heading", "label": "Título da seção", "default": "Compre por categoria" }
  ],
  "blocks": [
    {
      "type": "category",
      "name": "Categoria",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Imagem" },
        { "type": "text", "id": "label", "label": "Nome", "default": "Categoria" },
        { "type": "url", "id": "link", "label": "Link" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Categorias",
      "blocks": [
        { "type": "category", "settings": { "label": "Pele" } },
        { "type": "category", "settings": { "label": "Cabelo" } },
        { "type": "category", "settings": { "label": "Gummies" } },
        { "type": "category", "settings": { "label": "Kits" } }
      ]
    }
  ]
}
{% endschema %}
