<section class="section" style="padding-top: var(--space-4);">
  <div class="container">
    <h2 class="section__heading font-heading">{{ section.settings.heading | default: 'você também vai gostar' }}</h2>
    <div class="product-grid product-grid--compact">
      {% assign count = 0 %}
      {% for collection_product in product.collections.first.products %}
        {% unless collection_product.id == product.id %}
          {% if count < 4 %}
            {% render 'product-card', product: collection_product, compact: true %}
            {% assign count = count | plus: 1 %}
          {% endif %}
        {% endunless %}
      {% endfor %}

      {% if count == 0 %}
        {% for other in collections.all.products limit: 4 %}
          {% unless other.id == product.id %}
            {% render 'product-card', product: other, compact: true %}
          {% endunless %}
        {% endfor %}
      {% endif %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Outros produtos",
  "settings": [ { "type": "text", "id": "heading", "label": "Título", "default": "você também vai gostar" } ]
}
{% endschema %}
